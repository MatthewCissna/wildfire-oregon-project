# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/

# Environments
.venv/
.env
.env.local

# uv
# (uv.lock IS committed for reproducibility — do not ignore it)

# Data — large/derived artifacts are not committed. Keep folder structure via .gitkeep.
data/raw/*
data/interim/*
data/processed/*
data/patches/*
!data/**/.gitkeep

# Outputs — regenerated by the pipeline.
outputs/*.log
outputs/maps/*
outputs/models/*
outputs/metrics/*
outputs/figures/*
!outputs/**/.gitkeep
# Keep the trained burn-scar detector so the Live Fire Watch CI can run the CNN
# confirmation (and so a fresh clone can score detections without retraining).
# Re-include the cnn/ dir first — git can't un-ignore a file under an excluded dir.
!outputs/models/cnn/
outputs/models/cnn/*
!outputs/models/cnn/fire_detector.pt

# Earth Engine / Google credentials — NEVER commit these.
*.json.key
credentials
.config/earthengine/
service-account*.json
gee-credentials*.json

# OS
.DS_Store
Thumbs.db

# Local Claude Code / tooling state
.claude/

# osmnx / HTTP response cache
cache/

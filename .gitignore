# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/

# Environments
.venv/
.env
.env.local

# uv
# (uv.lock IS committed for reproducibility — do not ignore it)

# Data — large/derived artifacts are not committed. Keep folder structure via .gitkeep.
data/raw/*
data/interim/*
data/processed/*
data/patches/*
!data/**/.gitkeep

# Outputs — regenerated by the pipeline.
outputs/*.log
outputs/maps/*
outputs/models/*
outputs/metrics/*
outputs/figures/*
!outputs/**/.gitkeep

# Earth Engine / Google credentials — NEVER commit these.
*.json.key
credentials
.config/earthengine/
service-account*.json
gee-credentials*.json

# OS
.DS_Store
Thumbs.db

# Local Claude Code / tooling state
.claude/
